# Leave unset for local prototype mode.
# Set to the launch backend origin to enable POST /api/launches/dry-run.
VITE_LAUNCH_API_BASE_URL=

# Server runtime.
PORT=8787
RPC_URL=https://api.devnet.solana.com
CORS_ORIGIN=http://127.0.0.1:5173
DATA_DIR=.data
RATE_LIMIT_WINDOW_MS=60000
RATE_LIMIT_MAX=120

# Optional durable API state. If unset, the API uses DATA_DIR JSON storage.
SUPABASE_URL=
SUPABASE_SERVICE_ROLE_KEY=
SUPABASE_STATE_TABLE=meteoras_console_state
SUPABASE_STATE_ROW_ID=default

# Optional fallback public keys used when a dry-run request does not include wallet.publicKey.
# The browser Phantom flow sends wallet.publicKey and uses it as payer, fee claimer, and pool creator.
LAUNCH_PAYER_PUBLIC_KEY=
LAUNCH_FEE_CLAIMER_PUBLIC_KEY=
LAUNCH_POOL_CREATOR_PUBLIC_KEY=

# Optional quote mint overrides. SOL defaults to wrapped SOL, USDC defaults to mainnet USDC.
QUOTE_MINT_SOL=
QUOTE_MINT_USDC=

# Used only when a launch request does not include token metadata URI.
DEFAULT_TOKEN_METADATA_URI=

# Server-side Pinata metadata agent. Keep the JWT private; the browser only receives public URLs.
PINATA_JWT=
PINATA_GATEWAY=
PINATA_MAX_IMAGE_BYTES=8388608
METADATA_UPLOAD_BODY_LIMIT_BYTES=12000000

# Keep false unless the reviewed Phantom signing flow is cleared for transaction submission.
ALLOW_MAINNET_EXECUTE=false

# Launch Bundler. Generates fresh wallets, funds them from the connected wallet,
# and bundle-buys a launched token for supply control. Submission is gated by
# ALLOW_MAINNET_EXECUTE like every other write path.
# Max wallets per bundle (UI caps at 30).
BUNDLER_MAX_WALLETS=30
# Extra SOL funded into each wallet to cover swap fees + ATA/wSOL rent.
BUNDLER_GAS_BUFFER_SOL=0.005
# Set a strong secret to AES-256-GCM encrypt bundle wallet private keys at rest.
# Leave unset to store them unencrypted in DATA_DIR/Supabase state (dev only).
BUNDLER_KEY_SECRET=
